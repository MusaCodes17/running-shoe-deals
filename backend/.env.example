# Database
DATABASE_URL=sqlite:///./shoe_deals.db

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# Scraping Settings
SCRAPE_DELAY_SECONDS=3
MAX_CONCURRENT_SCRAPERS=2
USER_AGENT=Personal Shoe Deal Finder Bot (contact@example.com)

# CORS (for development)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Scheduling
SCRAPE_SCHEDULE_HOURS=6  # Run scraping every 6 hours
