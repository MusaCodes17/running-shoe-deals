# Base URL for the backend API. During `npm run dev` the Vite proxy forwards
# /api requests to http://localhost:8000, so the default empty value works.
# Set this when serving the built frontend separately from the backend.
VITE_API_URL=

# Bearer token for the R2.1 auth layer. MUST equal the backend's ANTON_SECRET
# (backend/.env). Baked into the built bundle and sent as `Authorization: Bearer`
# on every request. Without it the SPA's calls 401 once auth is active.
# (Vite reads env from this frontend/ directory, so it lives here — not in
# backend/.env, which Vite never reads.)
VITE_ANTON_SECRET=
