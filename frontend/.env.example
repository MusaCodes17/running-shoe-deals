# Base URL for the backend API. During `npm run dev` the Vite proxy forwards
# /api requests to http://localhost:8000, so the default empty value works.
# Set this when serving the built frontend separately from the backend.
VITE_API_URL=

# RA2.1: the SPA no longer carries a baked bearer token. Auth is now an httpOnly
# `anton_session` cookie issued after a password login (POST /api/auth/session)
# and sent automatically via withCredentials. The built bundle holds no secret,
# so there is nothing to configure here — the old VITE_ANTON_SECRET is retired.
